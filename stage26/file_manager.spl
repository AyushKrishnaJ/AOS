alias retVal R0;
alias functionNum R1;
alias arg1 R2;
alias arg2 R3;
alias arg3 R4;

// arguements (arg1 : disk block number, arg2 : offset, arg3 : memory address to save value at)
// no return
if (functionNum == BUFFERED_READ || BUFFERED_WRITE) then
    // get buffer number (b/w 0 and 3 inclusive)
    alias bufferNum R5;
    bufferNum = arg1 % MAX_BUFFER;

    // acquire the buffer resource
    multipush(R0, R1, R2, R3, R4, R5);
    R1 = ACQUIRE_BUFFER;
    R2 = bufferNum;
    R3 = [SYSTEM_STATUS_TABLE + 1];

    call RESOURCE_MANAGER;
    multipop(R0, R1, R2, R3, R4, R5);

    // if current block in buffer is not the block we are about to place
    if ([BUFFER_TABLE + bufferNum * 4 + 0] != arg1) then
        // if the dirty bit is set
        if ([BUFFER_TABLE + bufferNum * 4 + 1] == 1) then
            multipush(R0, R1, R2, R3, R4, R5);
            R1 = DISK_STORE;
            R2 = [SYSTEM_STATUS_TABLE + 1]; // pid
            R3 = BUFFER_BASE + bufferNum; // page number
            R4 = [BUFFER_TABLE + bufferNum * 4 + 0]; // block number

            call DEVICE_MANAGER;
            multipop(R0, R1, R2, R3, R4, R5);

            [BUFFER_TABLE + bufferNum * 4 + 1] = 0;
        endif;

        multipush(R0, R1, R2, R3, R4, R5);
        R1 = DISK_LOAD;
        R4 = arg1;
        R2 = [SYSTEM_STATUS_TABLE + 1]; // pid
        R3 = BUFFER_BASE + bufferNum;

        call DEVICE_MANAGER;
        multipop(R0, R1, R2, R3, R4, R5);

        [BUFFER_TABLE + bufferNum * 4 + 0] = arg1;
    endif;

    if (functionNum == BUFFERED_WRITE) then
        [(BUFFER_BASE + bufferNum) * 512 + arg2] = arg3;
        [BUFFER_TABLE + bufferNum * 4 + 1] = 1;
    else
        [arg3] = [(BUFFER_BASE + bufferNum) * 512 + arg2];
    endif;

    multipush(R0, R1, R2, R3, R4, R5);
    R1 = RELEASE_BUFFER;
    R2 = bufferNum;
    R3 = [SYSTEM_STATUS_TABLE + 1];

    call RESOURCE_MANAGER;
    multipop(R0, R1, R2, R3, R4, R5);
endif;

// arguements (filename)
// return file table index or -1(error code) or -2(no free entry in open file table)
if (functionNum == OPEN) then
    alias iter R5;
    alias inodeIndex R6;

    iter = 0;

    // find corresponding inode index
    while (iter < MAX_FILE_NUM) do
    if ([INODE_TABLE + iter * 16 + 1] == arg1) then
        inodeIndex = iter;
        break;
    endif;
        iter = iter + 1;
    endwhile;

    if (iter == MAX_FILE_NUM) then
        R0 = -1; // no file with such a file name
        return;
    endif;

    multipush(R1, R2, R3, R4, R5, R6);
    R1 = ACQUIRE_INODE; // function Num
    R2 = inodeIndex; // index in inode table
    R3 = [SYSTEM_STATUS_TABLE + 1]; // process pid

    call RESOURCE_MANAGER;

    multipop(R1, R2, R3, R4, R5, R6);
    // if acquire inode fails, return -1 for open function call aswell
    if (R0 == -1) then
        R0 = -1;
        return;
    endif;

    // only data files can be opened
    if ([INODE_TABLE + inodeIndex * 16 + 0] == EXEC) then
        multipush(R0, R1, R2, R3, R4, R5, R6);
        R1 = RELEASE_INODE;
        R2 = inodeIndex;
        R3 = [SYSTEM_STATUS_TABLE + 1];

        call RESOURCE_MANAGER;
        multipop(R0, R1, R2, R3, R4, R5, R6);

        R0 = -1;
        return;
    endif;

    // get a free entry in open file table
    iter = 0;
    alias ofTableIndex R7;
    while (iter < MAX_OPENFILE_NUM) do
        if ([OPEN_FILE_TABLE + iter * 4 + 0] == -1) then
            break;
        endif;

        iter = iter + 1;
    endwhile;

    if (iter == MAX_OPENFILE_NUM) then
        multipush(R0, R1, R2, R3, R4, R5, R6);
        R1 = RELEASE_INODE;
        R2 = inodeIndex;
        R3 = [SYSTEM_STATUS_TABLE + 1];

        call RESOURCE_MANAGER;
        multipop(R0, R1, R2, R3, R4, R5, R6);

        R0 = -2;
        return;
    endif;

    ofTableIndex = iter;

    if (arg1 == "root") then
        [OPEN_FILE_TABLE + ofTableIndex * 4 + 0] = INODE_ROOT;
    
    else
        // increment count in file status table and set corresponding inode index in open file table
        if ([FILE_STATUS_TABLE + inodeIndex * 4 + 1] == -1) then
            [FILE_STATUS_TABLE + inodeIndex * 4 + 1] = 1;

        else
            [FILE_STATUS_TABLE + inodeIndex * 4 + 1] = [FILE_STATUS_TABLE + inodeIndex * 4 + 1] + 1;

        endif;
            [OPEN_FILE_TABLE + ofTableIndex * 4 + 0] = inodeIndex;

    endif;

    // set open instance count and lseek
    [OPEN_FILE_TABLE + ofTableIndex * 4 + 1] = 1;
    [OPEN_FILE_TABLE + ofTableIndex * 4 + 2] = 0;

    // call release inode
    multipush(R0, R1, R2, R3, R4, R5, R6, R7);
    R1 = RELEASE_INODE;
    R2 = inodeIndex;
    R3 = [SYSTEM_STATUS_TABLE + 1];

    call RESOURCE_MANAGER;
    multipop(R0, R1, R2, R3, R4, R5, R6, R7);

    R0 = ofTableIndex;
    return;
endif;

// arguements (open file table index)
// no return
if (functionNum == CLOSE) then
    // find inode index
    alias inodeIndex R5;
    inodeIndex = [OPEN_FILE_TABLE + arg1 * 4 + 0];

    // decrement open instance count
    [OPEN_FILE_TABLE + arg1 * 4 + 1] = [OPEN_FILE_TABLE + arg1 * 4 + 1] - 1;

    // no more process has this file opened, so clear the entry
    if ([OPEN_FILE_TABLE + arg1 * 4 + 1] == 0) then
        [OPEN_FILE_TABLE + arg1 * 4 + 0] = -1;
        [OPEN_FILE_TABLE + arg1 * 4 + 1] = -1;
        [OPEN_FILE_TABLE + arg1 * 4 + 2] = -1;

        // if its not root then decrement file_oepn_count in file status table
        if (inodeIndex != INODE_ROOT) then
            [FILE_STATUS_TABLE + inodeIndex * 4 + 1] = [FILE_STATUS_TABLE + inodeIndex * 4 + 1] - 1;

            // if it reaches 0, reset to -1
            if ([FILE_STATUS_TABLE + inodeIndex * 4 + 1] == 0) then
                [FILE_STATUS_TABLE + inodeIndex * 4 + 1] = -1;
            endif;
        endif;
    endif;
endif;

return;